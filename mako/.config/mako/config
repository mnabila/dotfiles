# ~/.config/mako/config

# Global defaults
max-visible=5
sort=-time
layer=overlay
anchor=top-right

# Layout
width=300
height=100
margin=10
padding=10,15

# Timing
default-timeout=5000
ignore-timeout=0

# Font
font=Iosevka NerdFont 10

# Gruvbox Dark Colors
background-color=#282828
text-color=#ebdbb2
border-color=#ebdbb2
border-size=1
icons=1
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=48

# Progress bar (e.g. for volume/brightness)
[urgency=low]
background-color=#282828
text-color=#ebdbb2
border-color=#ebdbb2
default-timeout=3000

[urgency=normal]
background-color=#3c3836
text-color=#ebdbb2
border-color=#ebdbb2
default-timeout=5000

[urgency=critical]
background-color=#cc241d
text-color=#fbf1c7
border-color=#fb4934
default-timeout=0
